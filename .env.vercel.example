# Vercel environment template for Restaurant POS Backend + Supabase
# Copy values into Vercel Project Settings > Environment Variables.
# Do not commit real passwords or secret keys.

NODE_ENV=production
DB_CLIENT=postgres
DB_SSL=true
DB_POOL_MAX=5

# Supabase Transaction Pooler URI. Replace [YOUR-PASSWORD] in Vercel only.
DATABASE_URL=postgresql://postgres.ycqvnjausdhdfdqounsy:[YOUR-PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?sslmode=require
SUPABASE_DATABASE_URL=postgresql://postgres.ycqvnjausdhdfdqounsy:[YOUR-PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?sslmode=require

# Supabase API and Storage
SUPABASE_URL=https://ycqvnjausdhdfdqounsy.supabase.co
SUPABASE_PUBLIC_URL=https://ycqvnjausdhdfdqounsy.supabase.co
SUPABASE_STORAGE_BUCKET=restaurant-pos-assets
STORAGE_DRIVER=supabase

# Use Supabase secret/service role key in backend only. Never expose this to frontend.
SUPABASE_SERVICE_ROLE_KEY=__SET_IN_VERCEL_ONLY__
SUPABASE_SECRET_KEY=__SET_IN_VERCEL_ONLY__

# Optional browser-safe publishable key, only if backend needs it later.
SUPABASE_PUBLISHABLE_KEY=__OPTIONAL__

# Auth
JWT_SECRET=__SET_STRONG_SECRET_IN_VERCEL__
JWT_EXPIRES=7d

# Vercel Cron authorization. Generate a long random value and keep it backend-only.
CRON_SECRET=__SET_STRONG_RANDOM_SECRET_IN_VERCEL__

# AI Assistant
OPENROUTER_API_KEY=__SET_IN_VERCEL_ONLY__
# Optional primary model. Leave empty if you want to start from OPENROUTER_MODEL_FALLBACKS.
OPENROUTER_MODEL=openrouter/free
# Comma-separated free model fallback chain. Backend tries the next one when a model is rate-limited/quota-limited.
OPENROUTER_MODEL_FALLBACKS=qwen/qwen3-next-80b-a3b-instruct:free,google/gemma-4-26b-a4b-it:free,meta-llama/llama-3.3-70b-instruct:free,nvidia/nemotron-nano-12b-v2-vl:free,liquid/lfm-2.5-1.2b-thinking:free,liquid/lfm-2.5-1.2b-instruct:free,meta-llama/llama-3.2-3b-instruct:free,nousresearch/hermes-3-llama-3.1-405b:free,qwen/qwen3-coder:free,cognitivecomputations/dolphin-mistral-24b-venice-edition:free
# Alias if you prefer this name; values are merged with OPENROUTER_MODEL_FALLBACKS.
OPENROUTER_FREE_MODELS=
OPENROUTER_SITE_URL=https://your-frontend-domain.vercel.app
OPENROUTER_SITE_NAME=Kebab POS System

# Frontend CORS origin. This must match the actual browser origin exactly.
FRONTEND_URL=https://your-frontend-domain.vercel.app
# Optional comma-separated extra origins, for preview/custom domains.
CORS_ORIGINS=https://restaurant-pos-dev.vercel.app,https://restaurant-pos.dev.vercel.app
